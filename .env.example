# Dominio público (vinoproia.com): canonical, Open Graph y sitemap usan esta URL.
# Ejemplo producción: BASE_URL=https://vinoproia.com
# BASE_URL=

# CORS: orígenes permitidos separados por coma. Vacío o * = todos (solo desarrollo).
# IMPORTANTE producción: no dejar vacío ni *; usar dominio(s) real(es) para seguridad.
# Ejemplo: CORS_ORIGINS=https://vinoproia.com,https://www.vinoproia.com
# CORS_ORIGINS=

# Stripe - Desarrollo (test) o Producción (live)
# Claves en https://dashboard.stripe.com/apikeys (cambia a "Claves en vivo" para producción)
# Desarrollo: STRIPE_SECRET_KEY=sk_test_...  |  Producción: STRIPE_SECRET_KEY=sk_live_...
STRIPE_SECRET_KEY=sk_test_tu_clave_aqui
# Opcional: clave pública para Stripe.js en front (si la usas)
STRIPE_PUBLISHABLE_KEY=pk_test_tu_clave_aqui
# Webhook: en desarrollo "stripe listen --forward-to http://localhost:8001/webhook-stripe"
# En producción: crea un webhook en https://dashboard.stripe.com/webhooks apuntando a https://tudominio.com/webhook-stripe
STRIPE_WEBHOOK_SECRET=whsec_tu_secret_aqui

# OpenRouter (agente sumiller en modo IA local, puerto 8080)
# Obtén la API Key en https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-tu-clave-real
OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions
# Modelo (gratuito: openai/gpt-3.5-turbo o google/gemini-2.0-flash-exp:free)
OPENROUTER_MODEL=openai/gpt-3.5-turbo

# QR personalizados (networking Turín): datos en la página que ve el contacto
# QR_EMAIL=hola@vinoproia.com
# QR_LINKEDIN=https://linkedin.com/in/tu-perfil
# QR_WHATSAPP=34600000000
# QR_CALENDLY=https://calendly.com/tu-link
# Opcional: webhook (POST JSON) cuando alguien escanea su QR (ej. Slack, Telegram bot)
# QR_WEBHOOK_URL=

# Dominio público (vinoproia.com): canonical, Open Graph y sitemap usan esta URL.
# Ejemplo producción: BASE_URL=https://vinoproia.com
# Railway: BASE_URL=https://vinopro-backend-production.up.railway.app (o tu URL)
# BASE_URL=

# CORS: orígenes permitidos separados por coma. Vacío o * = todos (solo desarrollo).
# IMPORTANTE producción: no dejar vacío ni *; usar dominio(s) real(es) para seguridad.
# Ejemplo: CORS_ORIGINS=https://vinoproia.com,https://www.vinoproia.com
# CORS_ORIGINS=

# Soporte técnico visible en menú y página legal
# SUPPORT_EMAIL=soporte@vinoproia.com

# Gemini / visión de etiquetas
# GOOGLE_API_KEY=tu_clave_real_de_google
# VINO_VISION_MODEL=gemini-2.0-flash

# Protección ligera para free tier
# RATE_LIMIT_WINDOW_SECONDS=60
# RATE_LIMIT_DEFAULT_PER_MINUTE=90
# RATE_LIMIT_HOT_PER_MINUTE=12

# Escáner: concurrencia máxima simultánea
# ESCANEO_MAX_CONCURRENT=4

# API4AI queda desactivada por defecto para ahorrar latencia.
# Solo actívala si quieres pistas diagnósticas extra.
# ENABLE_API4AI_SCAN_HINTS=0

# Stripe - Desarrollo (test) o Producción (live)
# Claves en https://dashboard.stripe.com/apikeys (cambia a "Claves en vivo" para producción)
# Desarrollo: STRIPE_SECRET_KEY=sk_test_...  |  Producción: STRIPE_SECRET_KEY=sk_live_...
STRIPE_SECRET_KEY=sk_test_tu_clave_aqui
# Opcional: clave pública para Stripe.js en front (si la usas)
STRIPE_PUBLISHABLE_KEY=pk_test_tu_clave_aqui
# Webhook: en desarrollo "stripe listen --forward-to http://localhost:8001/webhook-stripe"
# En producción: crea un webhook en https://dashboard.stripe.com/webhooks apuntando a https://tudominio.com/webhook-stripe
STRIPE_WEBHOOK_SECRET=whsec_tu_secret_aqui

# OpenRouter (agente experto en vinos en modo IA local, puerto 8080)
# Obtén la API Key en https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-tu-clave-real
OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions
# Modelo (gratuito: openai/gpt-3.5-turbo o google/gemini-2.0-flash-exp:free)
OPENROUTER_MODEL=openai/gpt-3.5-turbo

# Reconocimiento de etiqueta por imagen (tipo Vivino). Opcional.
# Por defecto se usa demo gratuita (límites): https://demo.api4ai.cloud
# Producción: regístrate en https://api4ai.cloud o RapidAPI y define:
# API4AI_API_URL=https://api4ai.cloud
# API4AI_API_KEY=tu_api_key_si_lo_requiere_el_plan

# ── Amazon Associates (afiliados) ──────────────────────────────────────────
# Tag global (fallback para países sin tag específico):
AMAZON_ASSOCIATE_TAG=vinoproia-21
#
# Tags por país (tienen prioridad sobre el global). Formato: AMAZON_TAG_XX
AMAZON_TAG_ES=vinoproia-21
AMAZON_TAG_JP=vinoproia-22
AMAZON_TAG_US=vinoproia20-22
AMAZON_TAG_UK=vinoproia07-21
AMAZON_TAG_DE=vinoproia08-21
AMAZON_TAG_FR=vinoproia0a-21
AMAZON_TAG_IT=vinoproia0f-21
AMAZON_TAG_BR=vinoproia20-20
AMAZON_TAG_IN=vinoproia-028-21
AMAZON_TAG_AU=vinoproia-22
# AMAZON_TAG_NL=pendiente
# AMAZON_TAG_NZ=pendiente
# ───────────────────────────────────────────────────────────────────────────

# Canal Noticias VINEROS: noticias de vino en vivo (GNews). Sin clave se usan noticias estáticas.
# Regístrate en https://gnews.io/ y pega la API key. Caché 2h para no gastar cuota.
# GNEWS_API_KEY=

# QR personalizados (networking Turín): datos en la página que ve el contacto
# QR_EMAIL=hola@vinoproia.com
# QR_LINKEDIN=https://linkedin.com/in/tu-perfil
# QR_WHATSAPP=34600000000
# QR_CALENDLY=https://calendly.com/tu-link
# Opcional: webhook (POST JSON) cuando alguien escanea su QR (ej. Slack, Telegram bot)
# QR_WEBHOOK_URL=

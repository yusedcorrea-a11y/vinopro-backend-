    "cepa_gavilán": {
        "nombre": "Cepa Gavilán",
        "bodega": "Hnos Pérez Pascuas",
        "region": "Ribera del Duero",
        "pais": "España",
        "tipo": "tinto",
        "puntuacion": 90,
        "precio_estimado": "20€",
        "descripcion": "Crianza de entrada de gama, frutal y equilibrado."
    },
    "tío_pepe": {
        "nombre": "Tío Pepe",
        "bodega": "González Byass",
        "region": "Jerez",
        "pais": "España",
        "tipo": "blanco",
        "puntuacion": 90,
        "precio_estimado": "8-12€",
        "descripcion": "El vino español más famoso del mundo. Fino seco y elegante."
    },
    "vino_mock": {
        "nombre": "Vino Mock",
        "bodega": "Bodega Mock",
        "region": "Por determinar",
        "pais": "España",
        "tipo": "tinto",
        "puntuacion": null,
        "precio_estimado": null,
        "descripcion": "Color rojo intenso | Aromas a fruta | Sabor equilibrado"
    }
# 2. Análisis normal para vinos no en DB
# 2. Análisis normal (continuación)
    texto_lower = texto.lower()
    
    tipo = "tinto"
    if "blanco" in texto_lower: tipo = "blanco"
    elif "rosado" in texto_lower: tipo = "rosado" 
    elif "espumoso" in texto_lower or "cava" in texto_lower or "champagne" in texto_lower: tipo = "espumoso"
    elif "dulce" in texto_lower or "oporto" in texto_lower: tipo = "fortificado"
    
    anio_match = re.search(r"\b(19\d{2}|20\d{2})\b", texto)
    anio = anio_match.group(1) if anio_match else "NV"
    
    bodega = "No especificada"
    if "bodega" in texto_lower or "château" in texto_lower or "domaine" in texto_lower:
        keywords = ["bodega", "château", "domaine", "winery", "bodegas", "weingut"]
        for keyword in keywords:
            if keyword in texto_lower:
                idx = texto_lower.find(keyword)
                fragmento = texto[idx:idx+100]
                palabras = fragmento.split()[1:5]
                if palabras:
                    bodega = " ".join(palabras).title()
                    break
    
    puntuacion = 70
    if "gran reserva" in texto_lower or "grand cru" in texto_lower: puntuacion = 90
    elif "reserva" in texto_lower or "premier cru" in texto_lower: puntuacion = 80
    elif "crianza" in texto_lower: puntuacion = 75
    
    if nombre_vino and nombre_vino.upper() != "DESCONOCIDO":
        nombre = nombre_vino
    else:
        nombre = texto.split(",")[0].strip()
    
    # Determinar país probable
    pais = "Desconocido"
    paises_keywords = {
        "españa": ["rioja", "ribera", "priorat", "jerez", "cava"],
        "francia": ["burdeos", "borgona", "champagne", "château", "domaine"],
        "italia": ["barolo", "brunello", "amarone", "prosecco", "toscana"],
        "usa": ["napa", "california", "oregon", "opus"],
        "argentina": ["mendoza", "malbec", "argentina"],
        "chile": ["maipo", "carmenere", "chile"],
        "alemania": ["riesling", "mosela", "alemania"],
        "portugal": ["oporto", "porto", "portugal"],
        "australia": ["shiraz", "australia", "penfolds"]
    }
    
    for p, keywords in paises_keywords.items():
        if any(keyword in texto_lower for keyword in keywords):
            pais = p.capitalize()
            break
    
    # Precio estimado según país y calidad
    precio = 20
    if pais == "Francia": precio = 50
    elif pais == "Italia": precio = 40
    elif pais == "España": precio = 25
    elif pais == "USA": precio = 45
    
    if puntuacion > 85: precio *= 2
    if puntuacion > 90: precio *= 3
    
    precio_min = max(5, int(precio * 0.7))
    precio_max = int(precio * 1.3)
    
    # Tiendas genéricas
    tiendas_genericas = [
        {"nombre": "Tiendas especializadas", "precio": f"{precio}€ aprox.", "url": "https://www.tiendadevinos.com/"},
        {"nombre": "El Corte Inglés", "precio": f"{precio+5}€ aprox.", "url": "https://www.elcorteingles.es/"},
        {"nombre": "Online", "precio": f"{precio}€ aprox.", "url": "https://www.wine-searcher.com/"}
    ]
    
    return {
        "nombre": nombre[:60],
        "bodega": bodega[:50],
        "region": "Por determinar",
        "pais": pais,
        "anio": anio,
        "puntuacion": min(100, max(50, puntuacion)),
        "tipo": tipo,
        "precio_estimado": f"{precio_min}-{precio_max}€",
        "precio_exacto": f"{precio}€ (aprox.)",
        "maridaje": ["Carnes rojas", "Quesos", "Pasta"] if tipo == "tinto" else ["Pescados", "Ensaladas", "Aperitivos"],
        "tiendas": tiendas_genericas,
        "puntuacion_wine": 3.8,
        "temperatura_servicio": "16-18°C" if tipo == "tinto" else "8-10°C",
        "potencial_guarda": "3-5 años",
        "descripcion": f"{tipo.title()} de {pais}. {nombre} es una buena elección.",
        "es_famoso": False,
        "en_db": False,
        "bandera": pais
    }

@app.post("/analyze/text")
async def analizar(texto: str = Form(...)):
    print(f"\n[ANALISIS] {texto}")
    
    try:
        prompt_text = f"Extrae SOLO el nombre del vino. Ejemplo: 'Château Margaux 2015' -> 'Château Margaux'. Si no claro: DESCONOCIDO\n\nTexto: {texto}\nNombre:"
        
        resp = requests.post(
            "http://localhost:11434/api/generate",
            json={
                "model": "qwen2.5:3b",
                "prompt": prompt_text,
                "stream": False,
                "options": {"temperature": 0.0}
            },
            timeout=15.0
        )
        
        respuesta_modelo = ""
        if resp.status_code == 200:
            data = resp.json()
            respuesta_modelo = data.get("response", "").strip()
            print(f"[MODELO] {respuesta_modelo}")
        
        analisis = analisis_inteligente(texto, respuesta_modelo)
        db_status = "EN BASE DE DATOS" if analisis.get("en_db") else "NO EN DB (análisis automático)"
        print(f"[RESULTADO] {db_status} - {analisis['nombre']} ({analisis['pais']})")
        
        return {"success": True, "analysis": analisis}
        
    except Exception as e:
        print(f"[ERROR] {e}")
        return {
            "success": True,
            "analysis": {
                "nombre": "Vino Analizado",
                "bodega": "Extraído",
                "region": "Internacional",
                "pais": "Desconocido",
                "anio": "2024",
                "puntuacion": 75,
                "tipo": "tinto",
                "precio_estimado": "20-40€",
                "precio_exacto": "30€ (aprox.)",
                "maridaje": ["Comida variada"],
                "tiendas": [
                    {"nombre": "Tienda local", "precio": "Consultar", "url": "#"},
                    {"nombre": "Supermercado", "precio": "20-40€", "url": "#"}
                ],
                "puntuacion_wine": 3.5,
                "temperatura_servicio": "12-14°C",
                "potencial_guarda": "3-5 años",
                "descripcion": "Análisis completado correctamente",
                "es_famoso": False,
                "en_db": False,
                "bandera": "🌍"
            }
        }

@app.get("/")
async def health_check():
    total_vinos = len(VINOS_MUNDIALES)
    paises = list(set([v["pais"] for v in VINOS_MUNDIALES.values()]))
    return {
        "status": "ok", 
        "service": "VINO PRO WORLD EDITION", 
        "version": "4.0", 
        "vinos_en_db": total_vinos,
        "paises": paises,
        "descripcion": f"Base de datos con {total_vinos} vinos de {len(paises)} países"
    }

@app.get("/vinos")
async def listar_vinos():
    """Endpoint para listar todos los vinos en la base de datos"""
    return {
        "total": len(VINOS_MUNDIALES),
        "vinos": [
            {
                "nombre": datos["nombre"],
                "pais": datos["pais"],
                "region": datos["region"],
                "tipo": datos["tipo"],
                "precio": datos["precio_rango"],
                "puntuacion": datos["puntuacion"]
            }
            for datos in VINOS_MUNDIALES.values()
        ]
    }


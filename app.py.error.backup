from fastapi import FastAPI, Form
from fastapi.middleware.cors import CORSMiddleware
import requests, uvicorn, json
import re

app = FastAPI()

# CONFIGURAR CORS
app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["POST", "GET", "OPTIONS"],
    allow_headers=["*"],
)

